{
  "name": "solana-programs",
  "version": "0.1.0",
  "description": "Dungeons & Moles Solana Programs",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 --ignore 'tests/session-manager/manual-session-delegate-flow.ts' --ignore 'tests/e2e/**/*.ts' tests/**/*.ts",
    "e2e:nft": "yarn run ts-mocha -p ./tsconfig.json -t 120000 tests/e2e/track1-nft/**/*.ts --exit",
    "e2e:gameplay": "yarn run ts-mocha -p ./tsconfig.json -t 300000 tests/e2e/track2-gameplay/**/*.ts --exit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@metaplex-foundation/mpl-core": "^1.7.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.4",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
