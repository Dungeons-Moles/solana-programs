{
  "version": "0.1.0",
  "name": "map_generator",
  "docs": ["Map Generator Program for deterministic procedural dungeon generation"],
  "instructions": [
    {
      "name": "initializeMapConfig",
      "docs": ["Initializes the map configuration with default seed mappings"],
      "accounts": [
        {
          "name": "mapConfig",
          "isMut": true,
          "isSigner": false,
          "docs": ["The map config PDA to initialize"]
        },
        {
          "name": "admin",
          "isMut": true,
          "isSigner": true,
          "docs": ["Admin who will control seed mappings"]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["System program for account creation"]
        }
      ],
      "args": []
    },
    {
      "name": "updateMapConfig",
      "docs": ["Updates the seed for a specific campaign level (admin only)"],
      "accounts": [
        {
          "name": "mapConfig",
          "isMut": true,
          "isSigner": false,
          "docs": ["The map config to update"]
        },
        {
          "name": "admin",
          "isMut": false,
          "isSigner": true,
          "docs": ["Must match config admin"]
        }
      ],
      "args": [
        {
          "name": "level",
          "type": "u8",
          "docs": ["Campaign level to update (0-80)"]
        },
        {
          "name": "seed",
          "type": "u64",
          "docs": ["New seed value for this level"]
        }
      ]
    },
    {
      "name": "batchUpdateMapConfig",
      "docs": ["Updates multiple seed mappings at once (admin only)"],
      "accounts": [
        {
          "name": "mapConfig",
          "isMut": true,
          "isSigner": false,
          "docs": ["The map config to update"]
        },
        {
          "name": "admin",
          "isMut": false,
          "isSigner": true,
          "docs": ["Must match config admin"]
        }
      ],
      "args": [
        {
          "name": "updates",
          "type": { "vec": { "defined": "SeedUpdate" } },
          "docs": ["List of level-seed pairs to update"]
        }
      ]
    },
    {
      "name": "getMapSeed",
      "docs": ["Returns the seed for a given campaign level (view function)"],
      "accounts": [
        {
          "name": "mapConfig",
          "isMut": false,
          "isSigner": false,
          "docs": ["The map config to read"]
        }
      ],
      "args": [
        {
          "name": "level",
          "type": "u8",
          "docs": ["Campaign level to query (0-80)"]
        }
      ],
      "returns": "u64"
    },
    {
      "name": "verifyMapHash",
      "docs": ["Verifies that a client-generated map matches expected hash for level"],
      "accounts": [
        {
          "name": "mapConfig",
          "isMut": false,
          "isSigner": false,
          "docs": ["The map config for seed lookup"]
        }
      ],
      "args": [
        {
          "name": "level",
          "type": "u8",
          "docs": ["Campaign level to verify"]
        },
        {
          "name": "mapHash",
          "type": { "array": ["u8", 32] },
          "docs": ["Hash of client-generated map"]
        }
      ],
      "returns": "bool"
    },
    {
      "name": "transferAdmin",
      "docs": ["Transfers admin authority to a new account"],
      "accounts": [
        {
          "name": "mapConfig",
          "isMut": true,
          "isSigner": false,
          "docs": ["The map config to update"]
        },
        {
          "name": "admin",
          "isMut": false,
          "isSigner": true,
          "docs": ["Current admin (must sign)"]
        },
        {
          "name": "newAdmin",
          "isMut": false,
          "isSigner": false,
          "docs": ["New admin to receive authority"]
        }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "MapConfig",
      "docs": ["Stores seed-to-level mappings for campaign levels"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "admin", "type": "publicKey", "docs": ["Authority that can update seeds"] },
          { "name": "seeds", "type": { "array": ["u64", 81] }, "docs": ["Seeds for levels 0-80"] },
          { "name": "version", "type": "u8", "docs": ["Config version for migrations"] },
          { "name": "bump", "type": "u8", "docs": ["PDA bump seed"] }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "SeedUpdate",
      "docs": ["A level-seed pair for batch updates"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "level", "type": "u8", "docs": ["Campaign level (0-80)"] },
          { "name": "seed", "type": "u64", "docs": ["New seed value"] }
        ]
      }
    },
    {
      "name": "TileType",
      "docs": ["Types of tiles in the generated map"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Floor" },
          { "name": "Wall" },
          { "name": "Gravel" },
          { "name": "Water" }
        ]
      }
    },
    {
      "name": "Position",
      "docs": ["A position on the map grid"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "x", "type": "u8" },
          { "name": "y", "type": "u8" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "MapConfigUpdated",
      "fields": [
        { "name": "admin", "type": "publicKey", "index": true },
        { "name": "level", "type": "u8", "index": false },
        { "name": "oldSeed", "type": "u64", "index": false },
        { "name": "newSeed", "type": "u64", "index": false },
        { "name": "timestamp", "type": "i64", "index": false }
      ]
    },
    {
      "name": "AdminTransferred",
      "fields": [
        { "name": "oldAdmin", "type": "publicKey", "index": true },
        { "name": "newAdmin", "type": "publicKey", "index": true },
        { "name": "timestamp", "type": "i64", "index": false }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "InvalidLevel", "msg": "Campaign level must be 0-80" },
    { "code": 6001, "name": "Unauthorized", "msg": "Signer is not the config admin" },
    { "code": 6002, "name": "ConfigAlreadyInitialized", "msg": "Map config is already initialized" },
    { "code": 6003, "name": "InvalidMapHash", "msg": "Map hash does not match expected value" },
    { "code": 6004, "name": "TooManyUpdates", "msg": "Batch update exceeds maximum allowed" }
  ]
}
