{
  "version": "0.1.0",
  "name": "player_inventory",
  "instructions": [
    {
      "name": "initializeInventory",
      "docs": [
        "Creates a new PlayerInventory account for a player.",
        "Initializes with 4 gear slots and no equipped items."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false,
          "docs": ["PDA: [\"inventory\", player.key()]"]
        },
        {
          "name": "player",
          "isMut": true,
          "isSigner": true,
          "docs": ["Player wallet, pays for account creation"]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "equipTool",
      "docs": [
        "Equips a tool item. If a tool is already equipped, it is replaced.",
        "The item must be a valid Tool type."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "itemId",
          "type": { "array": ["u8", 8] }
        },
        {
          "name": "tier",
          "type": { "defined": "Tier" }
        }
      ]
    },
    {
      "name": "equipGear",
      "docs": [
        "Equips a gear item in an available slot.",
        "Fails if no gear slots are available."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "itemId",
          "type": { "array": ["u8", 8] }
        },
        {
          "name": "tier",
          "type": { "defined": "Tier" }
        }
      ]
    },
    {
      "name": "unequipGear",
      "docs": [
        "Removes a gear item from a specific slot.",
        "The item is discarded (not stored elsewhere)."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "slotIndex",
          "type": "u8"
        }
      ]
    },
    {
      "name": "fuseItems",
      "docs": [
        "Fuses two identical items to produce one item at the next tier.",
        "Both items must have the same item_id and tier.",
        "For gear items, specify two gear slot indices."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "slotA",
          "type": "u8",
          "docs": ["First gear slot index (0-7)"]
        },
        {
          "name": "slotB",
          "type": "u8",
          "docs": ["Second gear slot index (0-7)"]
        }
      ]
    },
    {
      "name": "applyToolOil",
      "docs": [
        "Applies a Tool Oil modification to the equipped tool.",
        "Each modification (+ATK, +SPD, +DIG) can only be applied once per tool."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "modification",
          "type": { "defined": "ToolOilModification" }
        }
      ]
    },
    {
      "name": "expandGearSlots",
      "docs": [
        "Increases gear slot capacity after defeating a boss.",
        "Week 1 boss: 4 -> 6 slots. Week 2 boss: 6 -> 8 slots."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "gameState",
          "isMut": false,
          "isSigner": false,
          "docs": ["GameState account to verify boss defeat"]
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": []
    },
    {
      "name": "getCombatEffects",
      "docs": [
        "Converts equipped items and active itemsets to ItemEffect arrays.",
        "Returns effects for use by the combat system."
      ],
      "accounts": [
        {
          "name": "inventory",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "player",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [],
      "returns": { "vec": { "defined": "ItemEffect" } }
    },
    {
      "name": "generateItemOffer",
      "docs": [
        "Generates a weighted item offer based on POI type, act, and boss weaknesses.",
        "Uses deterministic seed for reproducibility."
      ],
      "accounts": [
        {
          "name": "gameState",
          "isMut": false,
          "isSigner": false,
          "docs": ["GameState for current act, week, and seed"]
        }
      ],
      "args": [
        {
          "name": "poiType",
          "type": { "defined": "PoiType" }
        },
        {
          "name": "seed",
          "type": "u64"
        }
      ],
      "returns": { "defined": "ItemOffer" }
    }
  ],
  "accounts": [
    {
      "name": "PlayerInventory",
      "docs": ["Player's equipped items and slot capacity"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "player", "type": "publicKey" },
          { "name": "tool", "type": { "option": { "defined": "ItemInstance" } } },
          { "name": "gear", "type": { "array": [{ "option": { "defined": "ItemInstance" } }, 8] } },
          { "name": "gearSlotCapacity", "type": "u8" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "ItemInstance",
      "docs": ["A specific item owned by a player"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "itemId", "type": { "array": ["u8", 8] }, "docs": ["References ItemDefinition ID"] },
          { "name": "tier", "type": { "defined": "Tier" } },
          { "name": "toolOilFlags", "type": "u8", "docs": ["Bitflags: 0x01=+ATK, 0x02=+SPD, 0x04=+DIG"] }
        ]
      }
    },
    {
      "name": "ItemOffer",
      "docs": ["A generated item offer at a POI"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "itemId", "type": { "array": ["u8", 8] } },
          { "name": "tier", "type": { "defined": "Tier" } },
          { "name": "price", "type": "u16" }
        ]
      }
    },
    {
      "name": "Tier",
      "docs": ["Item upgrade tier"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "I" },
          { "name": "II" },
          { "name": "III" }
        ]
      }
    },
    {
      "name": "ToolOilModification",
      "docs": ["Type of Tool Oil modification"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "PlusAtk" },
          { "name": "PlusSpd" },
          { "name": "PlusDig" }
        ]
      }
    },
    {
      "name": "PoiType",
      "docs": ["Point of Interest types that offer items"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "SupplyCache" },
          { "name": "ToolCrate" },
          { "name": "GeodeVault" },
          { "name": "SmugglerHatch" },
          { "name": "CounterCache" }
        ]
      }
    },
    {
      "name": "ItemType",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Tool" },
          { "name": "Gear" }
        ]
      }
    },
    {
      "name": "ItemTag",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Stone" },
          { "name": "Scout" },
          { "name": "Greed" },
          { "name": "Blast" },
          { "name": "Frost" },
          { "name": "Rust" },
          { "name": "Blood" },
          { "name": "Tempo" }
        ]
      }
    },
    {
      "name": "Rarity",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Common" },
          { "name": "Rare" },
          { "name": "Heroic" },
          { "name": "Mythic" }
        ]
      }
    },
    {
      "name": "ItemEffect",
      "docs": ["Combat effect (matches combat-system types)"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "trigger", "type": { "defined": "TriggerType" } },
          { "name": "oncePerTurn", "type": "bool" },
          { "name": "effectType", "type": { "defined": "EffectType" } },
          { "name": "value", "type": "i16" }
        ]
      }
    },
    {
      "name": "TriggerType",
      "docs": ["When an effect triggers (matches combat-system)"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "BattleStart" },
          { "name": "FirstTurn" },
          { "name": "TurnStart" },
          { "name": "EveryOtherTurn" },
          { "name": "OnHit" },
          { "name": "Exposed" },
          { "name": "Wounded" }
        ]
      }
    },
    {
      "name": "EffectType",
      "docs": ["Effect types (matches combat-system)"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "DealDamage" },
          { "name": "DealNonWeaponDamage" },
          { "name": "Heal" },
          { "name": "GainArmor" },
          { "name": "GainAtk" },
          { "name": "GainSpd" },
          { "name": "ApplyChill" },
          { "name": "ApplyShrapnel" },
          { "name": "ApplyRust" },
          { "name": "ApplyBleed" },
          { "name": "RemoveArmor" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "InventoryInitialized",
      "fields": [
        { "name": "player", "type": "publicKey", "index": false }
      ]
    },
    {
      "name": "ItemEquipped",
      "fields": [
        { "name": "player", "type": "publicKey", "index": false },
        { "name": "itemId", "type": { "array": ["u8", 8] }, "index": false },
        { "name": "tier", "type": { "defined": "Tier" }, "index": false },
        { "name": "slot", "type": "string", "index": false }
      ]
    },
    {
      "name": "ItemUnequipped",
      "fields": [
        { "name": "player", "type": "publicKey", "index": false },
        { "name": "itemId", "type": { "array": ["u8", 8] }, "index": false },
        { "name": "slotIndex", "type": "u8", "index": false }
      ]
    },
    {
      "name": "ItemFused",
      "fields": [
        { "name": "player", "type": "publicKey", "index": false },
        { "name": "itemId", "type": { "array": ["u8", 8] }, "index": false },
        { "name": "oldTier", "type": { "defined": "Tier" }, "index": false },
        { "name": "newTier", "type": { "defined": "Tier" }, "index": false }
      ]
    },
    {
      "name": "GearSlotsExpanded",
      "fields": [
        { "name": "player", "type": "publicKey", "index": false },
        { "name": "oldCapacity", "type": "u8", "index": false },
        { "name": "newCapacity", "type": "u8", "index": false }
      ]
    },
    {
      "name": "ToolOilApplied",
      "fields": [
        { "name": "player", "type": "publicKey", "index": false },
        { "name": "modification", "type": { "defined": "ToolOilModification" }, "index": false }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "InventoryFull", "msg": "No available gear slots" },
    { "code": 6001, "name": "InvalidItemId", "msg": "Item ID does not exist" },
    { "code": 6002, "name": "WrongItemType", "msg": "Item type does not match slot type" },
    { "code": 6003, "name": "FusionMismatch", "msg": "Items must have same ID and tier to fuse" },
    { "code": 6004, "name": "AlreadyMaxTier", "msg": "Item is already at maximum tier" },
    { "code": 6005, "name": "NoToolEquipped", "msg": "No tool is currently equipped" },
    { "code": 6006, "name": "ToolOilAlreadyApplied", "msg": "This Tool Oil modification was already applied" },
    { "code": 6007, "name": "SlotEmpty", "msg": "The specified slot is empty" },
    { "code": 6008, "name": "InvalidSlotIndex", "msg": "Slot index is out of bounds" },
    { "code": 6009, "name": "Unauthorized", "msg": "Signer is not the inventory owner" },
    { "code": 6010, "name": "AlreadyMaxSlots", "msg": "Gear slots already at maximum capacity" }
  ]
}
