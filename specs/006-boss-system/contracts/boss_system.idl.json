{
  "version": "0.1.0",
  "name": "boss_system",
  "instructions": [
    {
      "name": "getBossForStage",
      "docs": [
        "Returns the boss definition for a given stage and week.",
        "This is a view function that returns data without modifying state."
      ],
      "accounts": [],
      "args": [
        {
          "name": "stage",
          "type": "u8",
          "docs": ["Campaign stage number (1-80)"]
        },
        {
          "name": "week",
          "type": { "defined": "Week" }
        }
      ],
      "returns": { "defined": "BossInfo" }
    },
    {
      "name": "getScaledBossStats",
      "docs": [
        "Returns scaled boss stats for a specific stage and week.",
        "Applies tier scaling and act baseline bonuses."
      ],
      "accounts": [],
      "args": [
        {
          "name": "stage",
          "type": "u8"
        },
        {
          "name": "week",
          "type": { "defined": "Week" }
        }
      ],
      "returns": { "defined": "ScaledBossStats" }
    },
    {
      "name": "getBossWeaknesses",
      "docs": [
        "Returns the two weakness tags for the boss at the given stage and week.",
        "Used by item offer generation for tag weighting."
      ],
      "accounts": [],
      "args": [
        {
          "name": "stage",
          "type": "u8"
        },
        {
          "name": "week",
          "type": { "defined": "Week" }
        }
      ],
      "returns": { "array": [{ "defined": "ItemTag" }, 2] }
    },
    {
      "name": "getBossEffects",
      "docs": [
        "Converts boss traits to ItemEffect array for combat system integration.",
        "Returns all effects that should be active for this boss."
      ],
      "accounts": [],
      "args": [
        {
          "name": "stage",
          "type": "u8"
        },
        {
          "name": "week",
          "type": { "defined": "Week" }
        }
      ],
      "returns": { "vec": { "defined": "ItemEffect" } }
    },
    {
      "name": "getBossCombatInput",
      "docs": [
        "Returns a complete CombatantInput struct for initializing boss combat.",
        "Includes scaled stats ready for combat system."
      ],
      "accounts": [],
      "args": [
        {
          "name": "stage",
          "type": "u8"
        },
        {
          "name": "week",
          "type": { "defined": "Week" }
        }
      ],
      "returns": { "defined": "CombatantInput" }
    }
  ],
  "accounts": [],
  "types": [
    {
      "name": "BossInfo",
      "docs": ["Summary information about a boss"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "id", "type": { "array": ["u8", 12] } },
          { "name": "name", "type": "string" },
          { "name": "emoji", "type": { "array": ["u8", 4] } },
          { "name": "biome", "type": { "defined": "Biome" } },
          { "name": "week", "type": { "defined": "Week" } },
          { "name": "bossIndex", "type": "u8" },
          { "name": "weaknessTags", "type": { "array": [{ "defined": "ItemTag" }, 2] } },
          { "name": "traitCount", "type": "u8" }
        ]
      }
    },
    {
      "name": "ScaledBossStats",
      "docs": ["Boss stats after applying stage/act scaling"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "hp", "type": "u16" },
          { "name": "atk", "type": "u8" },
          { "name": "arm", "type": "u8" },
          { "name": "spd", "type": "u8" },
          { "name": "dig", "type": "u8" },
          { "name": "strikes", "type": "u8", "docs": ["Base strikes per turn (some bosses have >1)"] }
        ]
      }
    },
    {
      "name": "CombatantInput",
      "docs": ["Input data for combat system (matches combat-system type)"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "hp", "type": "i16" },
          { "name": "maxHp", "type": "u16" },
          { "name": "atk", "type": "i16" },
          { "name": "arm", "type": "i16" },
          { "name": "spd", "type": "i16" },
          { "name": "dig", "type": "i16" },
          { "name": "strikes", "type": "u8" }
        ]
      }
    },
    {
      "name": "Biome",
      "docs": ["Biome type for boss categorization"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "A" },
          { "name": "B" }
        ]
      }
    },
    {
      "name": "Week",
      "docs": ["Week within a run (determines boss pool)"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "One" },
          { "name": "Two" },
          { "name": "Three" }
        ]
      }
    },
    {
      "name": "ItemTag",
      "docs": ["Item tags for weakness matching (matches player-inventory)"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Stone" },
          { "name": "Scout" },
          { "name": "Greed" },
          { "name": "Blast" },
          { "name": "Frost" },
          { "name": "Rust" },
          { "name": "Blood" },
          { "name": "Tempo" }
        ]
      }
    },
    {
      "name": "ItemEffect",
      "docs": ["Combat effect (matches combat-system type)"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "trigger", "type": { "defined": "TriggerType" } },
          { "name": "oncePerTurn", "type": "bool" },
          { "name": "effectType", "type": { "defined": "EffectType" } },
          { "name": "value", "type": "i16" }
        ]
      }
    },
    {
      "name": "TriggerType",
      "docs": ["When an effect triggers (matches combat-system)"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "BattleStart" },
          { "name": "FirstTurn" },
          { "name": "TurnStart" },
          { "name": "EveryOtherTurn" },
          { "name": "OnHit" },
          { "name": "Exposed" },
          { "name": "Wounded" },
          { "name": "Countdown", "fields": [{ "name": "turns", "type": "u8" }] }
        ]
      }
    },
    {
      "name": "EffectType",
      "docs": ["Effect types (matches combat-system with boss extensions)"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "DealDamage" },
          { "name": "DealNonWeaponDamage" },
          { "name": "Heal" },
          { "name": "GainArmor" },
          { "name": "GainAtk" },
          { "name": "GainSpd" },
          { "name": "ApplyChill" },
          { "name": "ApplyShrapnel" },
          { "name": "ApplyRust" },
          { "name": "ApplyBleed" },
          { "name": "RemoveArmor" },
          { "name": "GainStrikes" },
          { "name": "StealGold" },
          { "name": "GoldToArmor" }
        ]
      }
    },
    {
      "name": "SpecialMechanic",
      "docs": ["Extended mechanics for complex boss traits"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "None" },
          { "name": "Reflection", "fields": [{ "name": "stacks", "type": "u8" }] },
          { "name": "Phase", "fields": [{ "name": "threshold", "type": "u8" }] },
          { "name": "Conditional", "fields": [{ "name": "condition", "type": { "defined": "Condition" } }] }
        ]
      }
    },
    {
      "name": "Condition",
      "docs": ["Conditions for conditional triggers"],
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "PlayerDigLessThan" },
          { "name": "PlayerExposed" },
          { "name": "ActsFirstTurn1" },
          { "name": "ReflectionDepleted" }
        ]
      }
    }
  ],
  "events": [],
  "errors": [
    { "code": 6000, "name": "InvalidStage", "msg": "Stage must be between 1 and 80" },
    { "code": 6001, "name": "BossNotFound", "msg": "No boss found for the given parameters" }
  ]
}
